# ============================================
# LegalLawAgent - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit the .env file to version control!
# ============================================

# -------------------------------------------
# Server Configuration
# -------------------------------------------
# Application environment: development, staging, production
NODE_ENV=development

# Port the backend server listens on
PORT=5000

# API version prefix for routes
API_VERSION=v1

# -------------------------------------------
# MongoDB Configuration
# -------------------------------------------
# MongoDB connection string
# For local development: mongodb://localhost:27017/legal_intelligence
# For production: use your MongoDB Atlas or hosted URI
MONGODB_URI=mongodb://localhost:27017/legal_intelligence

# -------------------------------------------
# JWT Configuration
# -------------------------------------------
# Secret key for signing access tokens (use a strong random string in production)
JWT_SECRET=your_jwt_secret_here_change_in_production

# Access token expiration (e.g., 7d, 1h, 30m)
JWT_EXPIRE=7d

# Secret key for signing refresh tokens (use a different strong random string)
JWT_REFRESH_SECRET=your_refresh_secret_here_change_in_production

# Refresh token expiration
JWT_REFRESH_EXPIRE=30d

# -------------------------------------------
# Frontend URL
# -------------------------------------------
# URL of the frontend application (used for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# -------------------------------------------
# File Upload Configuration
# -------------------------------------------
# Maximum file upload size in bytes (default: 10MB = 10485760)
MAX_FILE_SIZE=10485760

# Directory path for uploaded files
UPLOAD_PATH=./uploads

# -------------------------------------------
# CrewAI Configuration
# -------------------------------------------
# CrewAI API endpoint URL
CREWAI_API_URL=https://your-crewai-instance.crewai.com

# CrewAI service bearer token for API authentication
CREWAI_BEARER_TOKEN=your_crewai_bearer_token_here

# CrewAI user-level bearer token
CREWAI_USER_BEARER_TOKEN=your_crewai_user_bearer_token_here

# -------------------------------------------
# Rate Limiting
# -------------------------------------------
# Time window for rate limiting in milliseconds (default: 15 minutes = 900000)
RATE_LIMIT_WINDOW_MS=900000

# Maximum number of requests per window
RATE_LIMIT_MAX_REQUESTS=100

# -------------------------------------------
# Logging
# -------------------------------------------
# Log level: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info

# Log file path
LOG_FILE=logs/app.log
